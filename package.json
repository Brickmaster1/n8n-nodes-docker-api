{
  "name": "n8n-nodes-docker-api",
  "version": "0.1.1",
  "description": "Interact with Docker via direct API (no Portainer required) — manage containers, stream logs, and automate infrastructure workflows",
  "keywords": [
    "n8n",
    "n8n-nodes",
    "n8n-community-node-package",
    "docker",
    "containers",
    "devops",
    "automation",
    "infrastructure"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ramygamal231/n8n-nodes-docker-api",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramygamal231/n8n-nodes-docker-api.git"
  },
  "author": "Ramy Gamal",
  "main": "index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "npx copyfiles -u 1 -f \"nodes/Docker/docker.svg\" dist/nodes/Docker && npx copyfiles -u 1 \"assets/**/*\" dist/assets/",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials --ext .ts",
    "lintfix": "eslint nodes credentials --ext .ts --fix",
    "prepublishOnly": "npm run build && npm run lint",
    "test": "jest"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DockerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Docker/Docker.node.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "copyfiles": "^2.4.1",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "jest": "^29.0.0",
    "n8n-core": "*",
    "n8n-workflow": "*",
    "prettier": "^2.7.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dockerode": "^4.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
